# Central sync store configuration. Copy to .env and fill in.

# Postgres connection string. Works with any Postgres: a local docker
# (see docker-compose.yml), a managed host (Supabase / Neon / RDS), or a VPS.
DATABASE_URL=postgres://counter:counter@localhost:5432/counter_central

# Port the HTTP server listens on.
PORT=4500

# Optional TLS. In production prefer terminating TLS at a reverse proxy / load
# balancer (nginx, Caddy, a cloud LB) and leaving these unset. Set both to have
# the server speak HTTPS directly.
# CENTRAL_TLS_KEY=/etc/counter/central.key
# CENTRAL_TLS_CERT=/etc/counter/central.crt

{
  "name": "counter-central",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Central sync store for Counter multi-shop (Phase 3, docs/phase3-network-and-sync.md §B6). Postgres-backed ingest + catalog endpoints matching the shop-side HTTP transport contract.",
  "engines": { "node": ">=20" },
  "scripts": {
    "migrate": "tsx src/migrate.ts",
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start:prod": "node dist/server.js",
    "shop:add": "tsx src/provisionShop.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  }
}

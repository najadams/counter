{
  "name": "counter",
  "version": "0.2.2",
  "description": "Keyboard-first Electron POS for a Ghanaian beverage shop. Anti-shrinkage forensics on every cedi.",
  "author": {
    "name": "Counter POS",
    "email": "najmadams1706@gmail.com"
  },
  "homepage": "https://github.com/najadams/counter",
  "license": "UNLICENSED",
  "private": true,
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "db:reset": "tsx scripts/db-reset.ts",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "seed:reset": "node scripts/reset-and-seed.cjs",
    "seed:demo": "node scripts/seed-demo-products.cjs",
    "backup": "node scripts/backup.cjs",
    "serve:lan": "tsx scripts/serve-lan.ts",
    "icons": "node scripts/build-icons.cjs",
    "test": "vitest",
    "typecheck": "tsc -b --noEmit",
    "dist:win": "npm run icons && npm run build && electron-builder --win --x64 --publish never",
    "dist:mac": "npm run icons && npm run build && electron-builder --mac --publish never",
    "dist:linux": "npm run icons && npm run build && electron-builder --linux --publish never",
    "dist:all": "npm run icons && npm run build && electron-builder -mwl --publish never",
    "postinstall": "electron-builder install-app-deps",
    "clean": "rm -rf dist-electron dist",
    "predev": "rm -rf dist-electron",
    "sync:central-stub": "tsx scripts/central-stub.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.3.0",
    "bonjour-service": "^1.2.1",
    "electron-log": "^5.2.0",
    "node-thermal-printer": "^4.4.5",
    "qrcode.react": "^4.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^10.0.0",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "electron": "^33.0.2",
    "electron-builder": "^25.1.7",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.9",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^2.1.3"
  },
  "engines": {
    "node": ">=20"
  },
  "build": {
    "appId": "com.counter.pos",
    "productName": "Counter",
    "copyright": "Copyright (c) 2026 Counter POS",
    "afterPack": "scripts/after-pack.cjs",
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "directories": {
      "output": "release/${version}",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "migrations/**/*",
      "scripts/lib/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "migrations",
        "to": "migrations",
        "filter": [
          "**/*.sql"
        ]
      },
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Counter-Setup-${version}-${arch}.${ext}",
      "publisherName": "Counter POS",
      "fileAssociations": []
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Counter",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "uninstallDisplayName": "Counter POS ${version}"
    },
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.business",
      "artifactName": "Counter-${version}-${arch}.${ext}",
      "darkModeSupport": true,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "icon": "build/icon.icns",
      "title": "Counter ${version}",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 140,
          "y": 200,
          "type": "file"
        },
        {
          "x": 400,
          "y": 200,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "linux": {
      "icon": "build/icons",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Office;Finance",
      "artifactName": "Counter-${version}-${arch}.${ext}",
      "synopsis": "Keyboard-first POS for beverage retail.",
      "description": "Counter is an offline-first point-of-sale for small beverage shops. Tracks every cedi from sale to bank, with anti-shrinkage audit trails.",
      "desktop": {
        "Name": "Counter",
        "Comment": "Keyboard-first POS",
        "Categories": "Office;Finance;",
        "StartupWMClass": "Counter"
      }
    }
  }
}
